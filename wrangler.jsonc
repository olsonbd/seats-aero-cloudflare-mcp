{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "seats-aero-cloudflare-mcp",
  "main": "src/index.ts",
  "compatibility_date": "2026-03-30",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "migrations": [
    {
      "tag": "v2",
      "deleted_classes": [
        "MyMCP"
      ]
    }
  ],
  "observability": {
    "enabled": true
  }
}
